{
  "name": "rate-repository-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@apollo/client": "^4.2.7",
    "@expo/metro-runtime": "~55.0.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "date-fns": "^4.4.0",
    "expo": "~55.0.28",
    "expo-constants": "~55.0.17",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.26",
    "formik": "^2.4.9",
    "graphql": "^16.14.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-web": "^0.21.0",
    "react-router-native": "^6.30.4",
    "use-debounce": "^10.1.1",
    "yup": "^1.7.1"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testTimeout": 60000,
    "setupFilesAfterEnv": [
      "<rootDir>/setupTests.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|react-router-native|@testing-library|test-renderer|@sentry/react-native|native-base))",
      "/node_modules/react-native-reanimated/plugin/"
    ]
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.1",
    "eslint-plugin-jest": "^29.15.5",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.20",
    "test-renderer": "1.2"
  }
}
